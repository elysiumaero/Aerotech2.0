/*
 * credentials.h.example — Copy this file to credentials.h and set your values.
 * credentials.h is excluded from version control (.gitignore).
 * Never commit the actual credentials.h file.
 *
 * AES_KEY_HEX must be 32 hex chars and match GCS/credentials.py AES_KEY.
 * Generate: python3 -c "import os; print(os.urandom(16).hex())"
 */

