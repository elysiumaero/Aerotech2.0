# GCS/credentials.py — Copy this file to credentials.py and fill in values.
# credentials.py is excluded from version control (.gitignore).
# Never commit the actual credentials.py file.
#
# AES_KEY must be exactly 32 hex characters (= 16 bytes = AES-128)
# and MUST match AES_KEY_HEX in ESP32/credentials.h exactly.
#
# Generate a random key (Linux/macOS):
#   python3 -c "import os; print(os.urandom(16).hex())"

AES_KEY        = "your32hexcharkey0000000000000000"   # 32 hex chars
ENCRYPT_ENABLED = False   # Set True only after BOTH GCS and ESP32 are updated
